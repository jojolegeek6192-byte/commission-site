# ─────────────────────────────────────────────
# DATABASE
# Local dev: leave as-is (SQLite file, zero setup)
# Production: create a free Postgres DB (Vercel Postgres,
# Neon, or Supabase all work) and paste its connection string here.
# ─────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─────────────────────────────────────────────
# NEXTAUTH
# Generate a secret with: openssl rand -base64 32
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# THE ONLY 2 ACCOUNTS THAT CAN LOG IN
# There is no sign-up page. These are the only credentials
# the app will ever accept. Passwords are hashed at runtime
# on first login attempt comparison — put the PLAIN password here,
# the app hashes/compares it securely server-side, it is never
# exposed to the client.
# ─────────────────────────────────────────────
OWNER_USERNAME="owner"
OWNER_PASSWORD="change-me-owner-password"

MANAGER_USERNAME="manager"
MANAGER_PASSWORD="change-me-manager-password"

# ─────────────────────────────────────────────
# FILE UPLOADS (Vercel Blob)
# Create a Blob store in your Vercel project dashboard
# (Storage tab -> Create Database -> Blob) and it will
# auto-populate this env var for you on deploy.
# For local dev, run `vercel env pull` after creating it.
# ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ─────────────────────────────────────────────
# NOTIFICATIONS
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
# ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxxxx/xxxxx"

# Optional email notifications via Resend (https://resend.com, free tier)
# Leave empty to disable email notifications entirely.
RESEND_API_KEY=""
NOTIFY_EMAIL_TO=""
NOTIFY_EMAIL_FROM="Commissions <onboarding@resend.dev>"
