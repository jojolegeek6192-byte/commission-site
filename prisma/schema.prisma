// Prisma schema — see DEPLOYMENT.md for production setup notes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
}

// Commission workflow. Distinct from `urgent`, which is a separate flag
// (a commission can be urgent at any status except CANCELLED/COMPLETED).
enum CommissionStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_FOR_PAYMENT
  PAID
  COMPLETED
  CANCELLED
}

enum Currency {
  EUR
  USD
  ROBUX
}

model Commission {
  id            String            @id @default(cuid())
  projectName   String
  discordUser   String
  description   String
  amount        Float             @default(0) // numeric price the client entered
  currency      Currency          @default(EUR)
  deadline      DateTime
  urgent        Boolean           @default(false)
  notes         String?
  referenceUrls String // JSON-encoded string array of uploaded file URLs
  status        CommissionStatus  @default(NOT_STARTED)
  createdByRole Role              @default(MANAGER) // who submitted it (client form = MANAGER-tier default, or MANAGER creating on client's behalf)
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([deadline])
  @@index([currency])
}

model Client {
  id           String       @id @default(cuid())
  name         String
  discordUser  String?      @unique
  email        String?
  notes        String?
  commissions  Commission[]
  createdAt    DateTime     @default(now())
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  category    String // e.g. "Build", "Graphics", "UI", "Scripting"
  imageUrl    String
  description String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  authorName String
  authorRole String?
  content   String
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}
